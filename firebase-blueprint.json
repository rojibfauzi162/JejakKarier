{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and career data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "client"] },
        "status": { "type": "string", "enum": ["Active", "Suspended", "Pending"] },
        "plan": { "type": "string", "enum": ["Free", "Pro", "Enterprise"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "profile": { "type": "object" },
        "dailyReports": { "type": "array" },
        "todoList": { "type": "array" },
        "onboardingCompleted": { "type": "boolean" }
      },
      "required": ["uid", "role"]
    },
    "Training": {
      "title": "Training",
      "description": "Training programs and courses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["id", "title"]
    },
    "SystemMetadata": {
      "title": "System Metadata",
      "description": "Global system configurations",
      "type": "object",
      "properties": {
        "list": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/trainings/{trainingId}": {
      "schema": "Training",
      "description": "Training documents"
    },
    "/system_metadata/tracking_configuration": {
      "schema": "SystemMetadata",
      "description": "Tracking configuration"
    },
    "/system_metadata/duitku_configuration": {
      "schema": "SystemMetadata",
      "description": "Duitku configuration"
    },
    "/system_metadata/landing_page_configuration": {
      "schema": "SystemMetadata",
      "description": "Landing page configuration"
    },
    "/system_metadata/mayar_configuration": {
      "schema": "SystemMetadata",
      "description": "Mayar configuration"
    },
    "/system_metadata/products_catalog": {
      "schema": "SystemMetadata",
      "description": "Products catalog"
    },
    "/system_metadata/legal_configuration": {
      "schema": "SystemMetadata",
      "description": "Legal configuration"
    },
    "/system_metadata/sales_notifications_list": {
      "schema": "SystemMetadata",
      "description": "Sales notifications list"
    },
    "/system_metadata/sales_popup_configuration": {
      "schema": "SystemMetadata",
      "description": "Sales popup configuration"
    }
  }
}
