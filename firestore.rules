rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin') || 
         (request.auth.token.email == "rojibfauzi@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules for Collections
    // ===============================================================

    // System configurations
    match /system_metadata/{configId} {
      // Publicly readable configurations
      allow read: if configId in ['tracking_configuration', 'landing_page_configuration', 'sales_notifications_list', 'products_catalog', 'legal_configuration', 'sales_popup_configuration'];
      
      // Other configs require authentication
      allow read: if isAuthenticated();
      
      // Only admins can write to system metadata
      allow write: if isAdmin();

      // Recursive match for any sub-data
      match /{allPaths=**} {
        allow read: if configId in ['tracking_configuration', 'landing_page_configuration', 'sales_notifications_list', 'products_catalog', 'legal_configuration', 'sales_popup_configuration'] || isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // User profiles and data
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Trainings
    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
