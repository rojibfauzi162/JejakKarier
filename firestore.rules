rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "rojibfauzi@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules for Collections
    // ===============================================================

    // PUBLIC CONFIGURATIONS - MUST BE READABLE BY EVERYONE
    match /system_metadata/tracking_configuration {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_metadata/landing_page_configuration {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_metadata/sales_notifications_list {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_metadata/products_catalog {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_metadata/legal_configuration {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_metadata/sales_popup_configuration {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_metadata/mayar_configuration {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Other System Metadata
    match /system_metadata/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /{allPaths=**} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // User profiles and data
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Trainings
    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
