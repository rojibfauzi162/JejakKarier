rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' || 
         request.auth.token.email == "rojibfauzi@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules for Collections
    // ===============================================================

    // User profiles and data
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // System configurations
    match /system_metadata/sales_notifications_list {
      allow read: if true;
      match /{document=**} {
        allow read: if true;
      }
    }
    match /system_metadata/tracking_configuration {
      allow read: if true; // Allow public read for tracking
    }
    match /system_metadata/landing_page_config {
      allow read: if true; // Allow public read for landing page
    }
    match /system_metadata/{allPaths=**} {
      allow read: if isAuthenticated(); // Restrict to authenticated users
      allow write: if isAdmin();
    }

    // Trainings
    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
